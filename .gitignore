# Python 
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
build/
dist/
.eggs/

# Environnements virtuels
.venv/
venv/
env/
ENV/

# Jupyter
.ipynb_checkpoints/
**/.ipynb_checkpoints/
*.nbconvert.ipynb

# Données (versionnées via DVC, pas git)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Modèles (versionnés via DVC, pas git)
# Exception : final_model.pkl est aussi commité dans Git pour que la CI
# puisse tester l'API et builder l'image Docker sans setup DVC remote.
models/*
!models/.gitkeep
!models/final_model.pkl

# MLflow
mlruns/
mlflow.db
mlartifacts/

# DVC
/dvc.lock.bak

# Secrets / config locale
.env
.env.local
*.secret

# Fichier de suivi interne (local-only)
PROGRESSION.md

# IDE
.idea/
.vscode/
*.iml
*.swp

# OS
.DS_Store
Thumbs.db
desktop.ini

# Tests / couverture
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/

# Docker
*.tar

# Logs
*.log
logs/
